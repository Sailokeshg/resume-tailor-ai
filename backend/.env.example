# Copy this file to .env and fill in your OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here
PORT=5000
DEFAULT_TAILOR_MODEL=GEMMA_4_31B_IT
KEYWORD_EXTRACTION_MODEL=deepseek/deepseek-chat-v3-0324:free
MATCH_ANALYSIS_MODEL=deepseek/deepseek-chat-v3-0324:free
OUTREACH_MODEL=google/gemma-4-31b-it:free
